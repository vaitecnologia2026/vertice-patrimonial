{
  "name": "vertice-patrimonial",
  "version": "3.1.0",
  "description": "Vértice — Sistema Integrado de Licenciamento · Vercel Deployment",
  "scripts": {
    "build": "npx prisma generate --schema=vertice-backend/prisma/schema.prisma",
    "start": "node vertice-backend/src/index.js",
    "dev": "nodemon vertice-backend/src/index.js",
    "db:push": "npx prisma db push --schema=vertice-backend/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate deploy --schema=vertice-backend/prisma/schema.prisma",
    "db:seed": "node vertice-backend/prisma/seed.js",
    "db:studio": "npx prisma studio --schema=vertice-backend/prisma/schema.prisma",
    "db:generate": "npx prisma generate --schema=vertice-backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.13.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
