{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "vertice-backend/lp-parceiros.html"
    }
  },
  "rewrites": [
    { "source": "/api/:path*",     "destination": "/api/index" },
    { "source": "/health",         "destination": "/api/index" },
    { "source": "/uploads/:path*", "destination": "/api/index" },
    { "source": "/lp/:path*",      "destination": "/api/index" },
    { "source": "/(.*)",           "destination": "/api/index" }
  ]
}
