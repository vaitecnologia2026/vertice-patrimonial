# ─── BANCO DE DADOS ──────────────────────────────────────────────
DATABASE_URL="postgresql://vertice_user:SENHA_FORTE@localhost:5432/vertice_db?schema=public"

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET="TROQUE_POR_STRING_ALEATORIA_256_BITS"
JWT_REFRESH_SECRET="TROQUE_POR_OUTRA_STRING_ALEATORIA_256_BITS"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── SERVIDOR ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
CORS_ORIGIN="https://seudominio.com.br"

# ─── UPLOAD ──────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# ─── LOGS ────────────────────────────────────────────────────────
LOG_LEVEL=info
